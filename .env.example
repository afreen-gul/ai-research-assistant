# --- LLM provider (gemini | xai | groq | openai) ---
LLM_PROVIDER=gemini

# Gemini — free tier at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# xAI Grok — paid; get a key at https://console.x.ai/
# LLM_PROVIDER=xai
# XAI_API_KEY=your_xai_api_key_here
# XAI_MODEL=grok-3-mini

# Groq — free tier; fast Llama models (NOT Grok) at https://console.groq.com/keys
# LLM_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — paid; get a key at https://platform.openai.com/api-keys
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# JWT secret for session auth (generate a random string for production)
JWT_SECRET=change-me-to-a-random-secret-key

# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL for CORS (set to your public URL in production)
FRONTEND_URL=http://localhost:5173

# Serve built React UI from FastAPI (set true in production Docker deploy)
# SERVE_FRONTEND=true

# Database path (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/research_assistant.db

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma

# Upload directory for PDFs
UPLOAD_DIR=./data/uploads

# Embedding model (local, free)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
